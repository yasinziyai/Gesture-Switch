{
  "name": "mac-gesture-tabs",
  "version": "0.2.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "node scripts/sync-mediapipe-assets.mjs",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "npm run build:electron && wait-on tcp:5173 file:dist-electron/main.js file:dist-electron/preload.cjs && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.electron.json --noEmit --pretty false"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "25.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.bamadar.macgesturetabs",
    "productName": "Mac Gesture Tabs",
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "extendInfo": {
        "NSCameraUsageDescription": "This app needs camera access to detect your hand gestures for tab switching."
      }
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ]
  }
}
